# =============================================================================
# Bitcoin Real-Time Pipeline — .gitignore
# Covers: Python, Rust, Kafka, Docker, MinIO, StarRocks, Iceberg, IDE
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
ENV/
env/

# UV
.uv/
uv.lock

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Jupyter
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Rust
# ---------------------------------------------------------------------------
target/
**/*.rs.bk
Cargo.lock
# Note: Cargo.lock IS committed for binary crates (rusty-blockparser)
# but ignored here since it lives in its own repo

# ---------------------------------------------------------------------------
# Java / Spark / Hive
# ---------------------------------------------------------------------------
*.class
*.jar
*.war
*.ear
*.log
derby.log
metastore_db/
spark-warehouse/
.ivy2/
.sbt/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# Never commit Docker data volumes
kafka-data/
minio-data/
hms-mysql-data/
starrocks-data/
starrocks-fe-meta/

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
*.snappy
*.lz4
*.zstd

# ---------------------------------------------------------------------------
# MinIO / S3
# ---------------------------------------------------------------------------
.minio.sys/
.s3cfg

# ---------------------------------------------------------------------------
# Iceberg
# ---------------------------------------------------------------------------
# Iceberg metadata and data files (stored in MinIO, not in git)
warehouse/

# ---------------------------------------------------------------------------
# StarRocks
# ---------------------------------------------------------------------------
# StarRocks FE/BE data directories
fe/meta/
be/storage/

# ---------------------------------------------------------------------------
# Bitcoin Core
# ---------------------------------------------------------------------------
bitcoin-core-data/
*.dat
*.log
*.pid
.lock
wallet.dat
peers.dat
fee_estimates.dat
mempool.dat
banlist.dat

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Secrets / Credentials
# ---------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
credentials.json
secrets.yaml
secrets.yml

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Checkpoints / State
# ---------------------------------------------------------------------------
checkpoint.json
checkpoint.json.tmp

# ---------------------------------------------------------------------------
# Claude Code
# ---------------------------------------------------------------------------
.claude/
